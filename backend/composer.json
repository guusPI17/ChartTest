{
    "name": "chart/api",
    "description": "API для парсинга HTML-отчётов",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-dom": "*",
        "ext-libxml": "*",
        "yiisoft/yii2": "~2.0.49"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "autoload": {
        "psr-4": {
            "app\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "app\\tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "config": {
        "vendor-dir": "vendor",
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "minimum-stability": "stable"
}
